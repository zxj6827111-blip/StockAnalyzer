SA__AUTO_PROMOTION__NOTIFY_ON_REJECTION=true
SA__AUTO_PROMOTION__NOTIFY_ON_TRAINING_SUMMARY=true
SA__AUTO_PROMOTION__NOTIFY_ON_MANUAL_RELEASE_PENDING=true

