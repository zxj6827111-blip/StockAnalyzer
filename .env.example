SA__APP__MODE=simulation
SA__DATA_SOURCE__PRIMARY=market_warehouse
SA__DATA_SOURCE__LOCAL_DATA_ROOT=artifacts/warehouse/package
SA__DATA_SOURCE__WAREHOUSE_DB_PATH=artifacts/warehouse/market.duckdb
SA__MARKET_WAREHOUSE__DB_PATH=artifacts/warehouse/market.duckdb
SA__MARKET_WAREHOUSE__PACKAGE_ROOT=artifacts/warehouse/package
SA__MARKET_WAREHOUSE__BOOTSTRAP_SOURCE_ROOT=artifacts/imports/tdx_offline_package
SA__TDX_SYNC__VIPDOC_ROOT=D:\通达信\vipdoc
SA__TDX_SYNC__OUTPUT_ROOT=artifacts/imports/tdx_offline_package
SA__TDX_SYNC__RUN_TIME=18:20
SA__TDX_SYNC__AUTO_RUN=false
SA__TDX_SYNC__REFRESH_BEFORE_EVOLUTION=false
TDX_VIPDOC_HOST_ROOT=D:/通达信/vipdoc
# NAS 推荐示例：SA_API_HOST_PORT=18001
SA_API_HOST_PORT=18001
SA__DATA_SOURCE__SWITCH_AFTER_FAILURES=3
SA__CACHE__BACKEND=memory
SA__CACHE__REDIS_URL=redis://localhost:6379/0
SA__NOTIFICATIONS__PRIMARY=console
SA__NOTIFICATIONS__BACKUP=console
SA__NOTIFICATIONS__PUSHPLUS_TOKEN=your_pushplus_token_here
SA__NOTIFICATIONS__WECOM_WEBHOOK=
SA__NOTIFICATIONS__FEISHU_WEBHOOK=
SA__NOTIFICATIONS__FEISHU_APP_ID=
SA__NOTIFICATIONS__FEISHU_APP_SECRET=
SA__NOTIFICATIONS__FEISHU_APP_RECEIVE_ID=
SA__NOTIFICATIONS__FEISHU_APP_RECEIVE_ID_TYPE=open_id
# For the daily post-market research digest, set PRIMARY to feishu or feishu_app
# after filling the matching Feishu credentials above.
# Example:
# SA__NOTIFICATIONS__PRIMARY=feishu_app
# SA__NOTIFICATIONS__BACKUP=console
# To broadcast the same notification to multiple Feishu custom apps, set:
# SA__NOTIFICATIONS__PRIMARY=feishu_app_broadcast
# SA__NOTIFICATIONS__FEISHU_APPS=[{"name":"personal","app_id":"cli_xxx","app_secret":"xxx","receive_id":"oc_xxx","receive_id_type":"chat_id"},{"name":"company","app_id":"cli_yyy","app_secret":"yyy","receive_id":"oc_yyy","receive_id_type":"chat_id"}]
# To also fan out notifications to enterprise Feishu departments or members:
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_ENABLED=true
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_APP_ID=cli_xxx
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_APP_SECRET=xxx
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_MODE=enterprise_department
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_DEPARTMENT_IDS=["od_xxx"]
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_MEMBER_IDS=[]
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_MEMBER_ID_TYPE=open_id
# SA__NOTIFICATIONS__FEISHU_ENTERPRISE_ALL_DEPARTMENT_ID=0
SA__WECOM_INTERACTION__ENABLED=false
SA__WECOM_INTERACTION__TOKEN=
SA__WECOM_INTERACTION__VERIFY_SIGNATURE=true
SA__WECOM_INTERACTION__ALLOWED_USERS=[]
SA__WECOM_INTERACTION__AUTO_RECONCILE_AFTER_BROKER_SNAPSHOT=true
SA__DASHBOARD__DEFAULT_TOTAL_ASSET=100000
SA__WECOM_INTERACTION__ENCODING_AES_KEY=
SA__WECOM_INTERACTION__RECEIVE_ID=
SA__WECOM_INTERACTION__ENFORCE_RECEIVE_ID=false
SA__FEISHU_INTERACTION__ENABLED=false
SA__FEISHU_INTERACTION__SUBSCRIPTION_MODE=webhook
SA__FEISHU_INTERACTION__VERIFICATION_TOKEN=
SA__FEISHU_INTERACTION__ALLOWED_USERS=[]
SA__FEISHU_INTERACTION__AUTO_RECONCILE_AFTER_BROKER_SNAPSHOT=true
SA__NOTIFICATION_FILTER__COOLDOWN_SEC=300
SA__NOTIFICATION_FILTER__MIN_SCORE=65
SA__NOTIFICATION_FILTER__MAX_SIGNALS_PER_RUN=5
SA__NOTIFICATION_FILTER__QUIET_WINDOWS=["11:30-13:00"]
SA__RECONCILE__POSITION_TOLERANCE=0.01
SA__RECONCILE__REQUIRE_BROKER_SNAPSHOT_AT_CLOSE=true
SA__COMMAND_CHANNEL__SECRET_KEY=replace_with_strong_secret

# API auth: all dangerous POST endpoints require a Bearer token or X-SA-API-Key header.
SA__SECURITY__API_AUTH_ENABLED=true
SA__SECURITY__API_TOKEN=
SA__SECURITY__NOTIFY_TEST_ENABLED=false
SA__SECURITY__SUPPRESS_PLAIN_TEST_NOTIFICATIONS=true

SA__BACKTEST_MATCHER__DYNAMIC_SLIPPAGE_ENABLED=true
SA__BACKTEST_MATCHER__MAX_DYNAMIC_SLIPPAGE_RATIO=0.012
SA__BACKTEST_MATCHER__SLIPPAGE_BY_STRATEGY={"trend":0.0015,"monster":0.0025}
SA__EVOLUTION__STRICT_DEPENDENCY_CHECK=true
SA__EVOLUTION__ACTIVE_CHAMPION_ID=champion_v7_202603
SA__EVOLUTION__CODE_COMMIT_ID=git:release-20260301-local
